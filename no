import pandas as pd
from snowflake_connection import get_snowflake_connection, read_connection_details

def fetch_data_in_chunks(conn, query, chunk_size=10000):
    """
    Fetch data in chunks to handle large datasets.
    """
    cur = conn.cursor()
    cur.execute(query)
    while True:
        chunk = cur.fetchmany(chunk_size)
        if not chunk:
            break
        yield chunk, [desc[0] for desc in cur.description]  # Columns are consistent for all chunks
    cur.close()

def get_column_names(conn, database, schema, table_name):
    """
    Dynamically fetch column names for a given table using Snowflake.
    """
    query = f"SHOW COLUMNS IN {database}.{schema}.{table_name}"
    cur = conn.cursor()
    cur.execute(query)
    columns = [row[2] for row in cur.fetchall()]  # Column names are in the third position
    cur.close()
    return columns

def generate_identical_columns_query(database, schema, table, columns):
    """
    Generate SQL query to identify columns with identical values (excluding NULLs and single characters).
    """
    conditions = []
    for col in columns:
        condition = f"({col} IS NOT NULL AND LENGTH({col}) > 1 AND REGEXP_LIKE({col}, '^(.)\\1*$'))"
        conditions.append(condition)

    query = f"SELECT * FROM {database}.{schema}.{table} WHERE {' OR '.join(conditions)}"
    return query

def find_identical_columns(df):
    """
    Identify columns where all non-NULL values have identical characters.
    """
    identical_columns = []
    for col in df.columns:
        non_null_values = df[col].dropna().astype(str).str.strip()
        if not non_null_values.empty and non_null_values.apply(lambda x: len(set(x)) == 1 and len(x) > 1).all():
            identical_columns.append(col)
    return identical_columns

if __name__ == "__main__":
    try:
        # Step 1: Read configuration details
        config_file = "config.json"
        config = read_connection_details(config_file)
        table_name = config.get("table_name")

        if not table_name:
            raise ValueError("Table name not specified in the configuration file.")

        # Step 2: Establish connection using existing framework
        print("Establishing connection to Snowflake...")
        conn, database_name, schema_name = get_snowflake_connection(config_file)
        print("Connection established successfully.")

        # Step 3: Fetch data in chunks
        query_data = f"SELECT * FROM {database_name}.{schema_name}.{table_name}"
        print(f"Fetching data using query: {query_data}")

        output_file = f"{table_name}.xlsx"
        with pd.ExcelWriter(output_file, engine="openpyxl") as writer:
            for i, (chunk, columns) in enumerate(fetch_data_in_chunks(conn, query_data, chunk_size=10000)):
                print(f"\nProcessing Chunk {i+1}...")
                df_chunk = pd.DataFrame(chunk, columns=columns)

                # Identify identical columns
                identical_columns = find_identical_columns(df_chunk)
                if identical_columns:
                    print(f"Identical columns in chunk {i+1}: {identical_columns}")
                    sql_query = generate_identical_columns_query(database_name, schema_name, table_name, identical_columns)

                    # Write chunk data and SQL query to Excel
                    df_chunk.to_excel(writer, sheet_name=f"Chunk_{i+1}_Data", index=False)
                    pd.DataFrame({"Identical Columns": identical_columns}).to_excel(writer, sheet_name=f"Chunk_{i+1}_Identical", index=False)
                    pd.DataFrame({"Generated Query": [sql_query]}).to_excel(writer, sheet_name=f"Chunk_{i+1}_Query", index=False)
                else:
                    print(f"No identical columns found in chunk {i+1}.")
                    pd.DataFrame({"Message": ["No identical columns found in this chunk"]}).to_excel(writer, sheet_name=f"Chunk_{i+1}_Message", index=False)

        print(f"\nResults written to: {output_file}")

    except Exception as e:
        print(f"Error: {e}")
    finally:
        print("Closing Snowflake connection.")
        conn.close()
