import pandas as pd
from snowflake_connection import get_snowflake_connection, read_connection_details
from sqlalchemy import create_engine
from snowflake.sqlalchemy import URL
import os

def get_column_names(engine, database, schema, table_name):
    """
    Dynamically fetch column names for a given table using Snowflake.
    """
    query = f"SHOW COLUMNS IN {database}.{schema}.{table_name}"
    with engine.connect() as connection:
        result = connection.execute(query)
        columns = [row[2] for row in result]  # Column names are in the third position
    return columns

def generate_identical_columns_query(database, schema, table, columns):
    """
    Generate SQL query to identify columns with identical values (excluding NULLs and single characters).
    """
    conditions = []
    for col in columns:
        condition = f"({col} IS NOT NULL AND LENGTH({col}) > 1 AND REGEXP_LIKE({col}, '^(.)\\1*$'))"
        conditions.append(condition)

    query = f"SELECT * FROM {database}.{schema}.{table} WHERE {' OR '.join(conditions)}"
    return query

def find_identical_columns(df):
    """
    Identify columns where all non-NULL values have identical characters.
    """
    identical_columns = []
    for col in df.columns:
        non_null_values = df[col].dropna().astype(str).str.strip()
        if not non_null_values.empty and non_null_values.apply(lambda x: len(set(x)) == 1 and len(x) > 1).all():
            identical_columns.append(col)
    return identical_columns

if __name__ == "__main__":
    try:
        # Step 1: Establish Snowflake connection
        config_file = "config.json"
        config = read_connection_details(config_file)
        snowflake_details = config["snowflake"]
        table_name = config.get("table_name")

        if not table_name:
            raise ValueError("Table name not specified in the configuration file.")

        engine = create_engine(URL(
            account=snowflake_details.get("account"),
            user=snowflake_details.get("user"),
            password=snowflake_details.get("password"),
            database=snowflake_details.get("database"),
            schema=snowflake_details.get("schema"),
            warehouse=snowflake_details.get("warehouse"),
            role=snowflake_details.get("role"),
            authenticator=snowflake_details.get("authenticator", "externalbrowser")
        ))
        print("Snowflake connection established successfully.")

        # Step 2: Dynamically fetch columns
        database_name = snowflake_details.get("database")
        schema_name = snowflake_details.get("schema")
        print(f"Fetching column names for table: {table_name}")
        columns = get_column_names(engine, database_name, schema_name, table_name)
        print(f"Columns fetched dynamically: {columns}")

        # Step 3: Fetch table data
        query_data = f"SELECT * FROM {database_name}.{schema_name}.{table_name}"
        print(f"\nGenerated Query to Fetch Data:\n{query_data}")
        df = pd.read_sql(query_data, engine)

        # Output Excel File Named After Table
        output_file = f"{table_name}.xlsx"

        if df.empty:
            print("\nNo data found in the table.")
            no_data_message = "No identical characters found"
            with pd.ExcelWriter(output_file, engine='openpyxl') as writer:
                pd.DataFrame({"Query": [query_data]}).to_excel(writer, sheet_name="Query", index=False)
                pd.DataFrame({"Result": [no_data_message]}).to_excel(writer, sheet_name="Results", index=False)
            print(f"Results written to: {output_file}")
        else:
            print("Data fetched successfully.")

            # Step 4: Identify identical columns
            print("\nChecking for columns with identical values...")
            identical_columns = find_identical_columns(df)

            with pd.ExcelWriter(output_file, engine='openpyxl') as writer:
                # Write Query
                pd.DataFrame({"Query": [query_data]}).to_excel(writer, sheet_name="Query", index=False)

                if not identical_columns:
                    print("\nNo columns found where values have identical characters.")
                    pd.DataFrame({"Result": ["No identical characters found"]}).to_excel(writer, sheet_name="Results", index=False)
                else:
                    print(f"\nIdentical columns found: {identical_columns}")
                    sql_query = generate_identical_columns_query(database_name, schema_name, table_name, identical_columns)
                    print("\nGenerated SQL Query to Identify Columns with Identical Values:")
                    print(sql_query)

                    # Write Results
                    pd.DataFrame({"Identical Columns": identical_columns}).to_excel(writer, sheet_name="Identical_Columns", index=False)
                    pd.DataFrame({"Generated Query": [sql_query]}).to_excel(writer, sheet_name="Generated_Query", index=False)

            print(f"Results written to: {output_file}")

    except Exception as e:
        print(f"Error: {e}")
    finally:
        print("Closing Snowflake connection.")
        engine.dispose()
