import snowflake.connector
import pandas as pd
from snowflake_connection import get_snowflake_connection

# Function to retrieve column names from the specified table
def get_columns_from_table(conn, schema_name, table_name):
    query = f"""
        SELECT COLUMN_NAME
        FROM INFORMATION_SCHEMA.COLUMNS
        WHERE TABLE_SCHEMA = '{schema_name}'
        AND TABLE_NAME = '{table_name}'
    """
    cur = conn.cursor()
    cur.execute(query)
    columns = [row[0] for row in cur.fetchall()]
    cur.close()
    return columns

# Function to calculate NULL percentage, non-null count, and NULL count for each column
def calculate_null_stats(conn, schema_name, table_name, columns):
    null_stats = []
    cur = conn.cursor()
    
    for column in columns:
        query = f"""
            SELECT 
                '{column}' AS column_name, 
                ROUND((COUNT(*) - COUNT({column})) * 100.0 / COUNT(*), 2) AS null_percentage,
                COUNT({column}) AS non_null_count,
                COUNT(*) - COUNT({column}) AS null_count
            FROM {schema_name}.{table_name}
        """
        cur.execute(query)
        result = cur.fetchone()
        null_stats.append({
            'column_name': result[0],
            'null_percentage': result[1],
            'non_null_count': result[2],
            'null_count': result[3]
        })
    
    cur.close()
    return null_stats

# Main function to run the process and write results to Excel
def main():
    # Get connection, schema, and table name from JSON config
    conn, database_name, schema_name, table_name = get_snowflake_connection('config.json')

    # Get all column names from the table
    columns = get_columns_from_table(conn, schema_name, table_name)

    # Calculate NULL percentage, non-null count, and NULL count for each column
    null_stats = calculate_null_stats(conn, schema_name, table_name, columns)

    # Convert the results to a Pandas DataFrame
    df = pd.DataFrame(null_stats)

    # Write the DataFrame to an Excel file
    output_file = 'null_stats_report.xlsx'
    df.to_excel(output_file, sheet_name='Null_Stats', index=False)

    print(f"Results written to {output_file}")

    # Close the Snowflake connection
    conn.close()

if __name__ == "__main__":
    main()
