def run_duplicate_check(conn, database, schema, table_name):
    print(f"\n Running duplicate validation on table: {database}.{schema}.{table_name}")
    cur = conn.cursor()

    # Get all columns
    column_query = f"""
        SELECT COLUMN_NAME
        FROM {database}.INFORMATION_SCHEMA.COLUMNS
        WHERE TABLE_SCHEMA = '{schema}'
        AND TABLE_NAME = '{table_name}'
        ORDER BY ORDINAL_POSITION
    """
    cur.execute(column_query)
    columns = [row[0] for row in cur.fetchall()]
    column_list = ', '.join([f'"{col}"' for col in columns])  # double quotes for Snowflake identifiers

    #  Build summary query
    summary_query = f"""
        SELECT COUNT(*) AS total_rows,
               COUNT(DISTINCT {column_list}) AS distinct_rows
        FROM "{database}"."{schema}"."{table_name}"
    """
    cur.execute(summary_query)
    total_rows, distinct_rows = cur.fetchone()
    duplicate_count = total_rows - distinct_rows

    # Store summary
    summary_df = pd.DataFrame([{
        "Table_Name": table_name,
        "Total_Rows": total_rows,
        "Distinct_Rows": distinct_rows,
        "Duplicate_Count": duplicate_count,
        "Has_Duplicates": "Yes" if duplicate_count > 0 else "No",
        "Summary_Query": summary_query.strip()
    }])

    # Build detailed query (sample duplicates)
    sample_df = pd.DataFrame()
    if duplicate_count > 0:
        groupby_query = f"""
            SELECT {column_list}, COUNT(*) AS dup_count
            FROM "{database}"."{schema}"."{table_name}"
            GROUP BY {column_list}
            HAVING COUNT(*) > 1
            LIMIT 5
        """
        print(f" Executing detailed duplicate check:\n{groupby_query.strip()}")
        cur.execute(groupby_query)
        rows = cur.fetchall()
        headers = [desc[0] for desc in cur.description]
        sample_df = pd.DataFrame(rows, columns=headers)
        sample_df.insert(0, "Table_Name", table_name)
        sample_df["Dup_Query"] = groupby_query.strip()

    cur.close()
    return summary_df, sample_df
