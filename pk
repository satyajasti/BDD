import pandas as pd

def run_duplicate_check(conn, database, schema, table_name):
    print(f"\n Running duplicate validation on table: {database}.{schema}.{table_name}")
    result_rows = []

    # Summary Query
    summary_query = f"""
        SELECT COUNT(*) AS total_rows,
               COUNT(DISTINCT *) AS distinct_rows
        FROM "{database}"."{schema}"."{table_name}"
    """

    cur = conn.cursor()
    cur.execute(summary_query)
    total_rows, distinct_rows = cur.fetchone()
    duplicate_count = total_rows - distinct_rows

    result_rows.append({
        "Table_Name": table_name,
        "Total_Rows": total_rows,
        "Distinct_Rows": distinct_rows,
        "Duplicate_Count": duplicate_count,
        "Has_Duplicates": "Yes" if duplicate_count > 0 else "No",
        "Summary_Query": summary_query.strip()
    })

    # Sample Duplicate Rows Query (only if duplicates exist)
    sample_df = pd.DataFrame()
    if duplicate_count > 0:
        groupby_query = f"""
            SELECT *, COUNT(*) AS dup_count
            FROM "{database}"."{schema}"."{table_name}"
            GROUP BY ALL
            HAVING COUNT(*) > 1
            LIMIT 5
        """
        print(f" Detailed duplicate query:\n{groupby_query.strip()}")
        cur.execute(groupby_query)
        columns = [col[0] for col in cur.description]
        rows = cur.fetchall()
        sample_df = pd.DataFrame(rows, columns=columns)
        sample_df.insert(0, "Table_Name", table_name)
        sample_df["Dup_Query"] = groupby_query.strip()

    cur.close()

    # Create DataFrames
    summary_df = pd.DataFrame(result_rows)

    return summary_df, sample_df



