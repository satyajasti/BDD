import pandas as pd

def read_pattern_rules(excel_path):
    df = pd.read_excel(excel_path)
    print("\n Loaded pattern rules from Excel:")
    print(df)
    return df

def run_pattern_validation(conn, rule_df, database):
    pattern_summary = []
    all_invalid_samples = []

    for _, row in rule_df.iterrows():
        table = row['Table'].strip()
        schema = row['Schema'].strip()
        column = row['Column'].strip()
        pattern = row['Pattern'].strip()
        validation_type = row['Validation_Type'].strip()

        full_table = f"{database}.{schema}.{table}"
        query = f"""
            SELECT *
            FROM "{database}"."{schema}"."{table}"
            WHERE NOT REGEXP_LIKE("{column}", '{pattern}')
            LIMIT 5
        """

        print(f"\n Running pattern validation: {validation_type}")
        print(f" Query: {query.strip()}")

        try:
            sample_df = pd.read_sql(query, conn)

            # Summary
            pattern_summary.append({
                "Table": table,
                "Schema": schema,
                "Column": column,
                "Validation_Type": validation_type,
                "Pattern": pattern,
                "Invalid_Count": len(sample_df),
                "Pattern_Query": query.strip()
            })

            if not sample_df.empty:
                sample_df.insert(0, "Validation_Type", validation_type)
                sample_df.insert(1, "Pattern", pattern)
                sample_df.insert(2, "Column", column)
                sample_df.insert(3, "Schema", schema)
                sample_df.insert(4, "Table", table)
                all_invalid_samples.append(sample_df)

        except Exception as e:
            print(f" Error running pattern check for {table}.{column}: {e}")
            pattern_summary.append({
                "Table": table,
                "Schema": schema,
                "Column": column,
                "Validation_Type": validation_type,
                "Pattern": pattern,
                "Invalid_Count": "Error",
                "Pattern_Query": str(e)
            })

    summary_df = pd.DataFrame(pattern_summary)
    samples_df = pd.concat(all_invalid_samples, ignore_index=True) if all_invalid_samples else pd.DataFrame()

    return summary_df, samples_df
