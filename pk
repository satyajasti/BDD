import pandas as pd
import os
from snowflake_connection import get_snowflake_connection


def get_non_timestamp_columns(conn, database, schema, table):
    query = f"""
        SELECT COLUMN_NAME, DATA_TYPE
        FROM {database}.INFORMATION_SCHEMA.COLUMNS
        WHERE TABLE_SCHEMA = '{schema}'
          AND TABLE_NAME = '{table}'
          AND DATA_TYPE NOT LIKE '%TIMESTAMP%'
    """
    print(f"Executing query for {database}.{schema}.{table}:")
    print(query)
    df = pd.read_sql(query, conn)
    return df['COLUMN_NAME'].tolist()


def extract_columns_for_source_only(input_file, output_file):
    input_df = pd.read_excel(input_file)
    conn, _, _, _, _, _ = get_snowflake_connection("config.json")

    try:
        records = []
        for _, row in input_df.iterrows():
            db = row['Database']
            schema = row['Schema']
            table = row['Table']
            columns = get_non_timestamp_columns(conn, db, schema, table)

            records.append({
                "Source_Database": db,
                "Source_Schema": schema,
                "Source_Table": table,
                "Target_Database": "",
                "Target_Schema": "",
                "Target_Table": "",
                "Compare_Columns": ", ".join(columns)
            })

        output_df = pd.DataFrame(records)
        os.makedirs(os.path.dirname(output_file), exist_ok=True)
        output_df.to_excel(output_file, index=False)
        print(f" Output saved to: {output_file}")

    finally:
        conn.close()
        print(" Snowflake connection closed.")


if __name__ == "__main__":
    extract_columns_for_source_only("source_tables.xlsx", "compare_config.xlsx")
