import pandas as pd
import os
from openpyxl import Workbook
from openpyxl.utils.dataframe import dataframe_to_rows
from snowflake_connection import get_snowflake_connection

def read_comparison_config(excel_path):
    df = pd.read_excel(excel_path)
    print("\n Loaded comparison config from Excel:")
    print(df)
    return df

def write_df_to_sheet(wb, sheet_name, df):
    print(f" Writing to sheet: {sheet_name} (Rows: {len(df)})")
    ws = wb.create_sheet(title=sheet_name)
    for row in dataframe_to_rows(df, index=False, header=True):
        if any(row):
            ws.append(row)

def run_table_comparison(config_file, output_dir="reports/table_comparisons"):
    os.makedirs(output_dir, exist_ok=True)
    config_df = read_comparison_config(config_file)

    # Get Snowflake connection
    conn, _, _, _, _, _ = get_snowflake_connection("config.json")

    for _, row in config_df.iterrows():
        src_table = row['Source_Table'].strip()
        src_schema = row['Source_Schema'].strip()
        tgt_table = row['Target_Table'].strip()
        tgt_schema = row['Target_Schema'].strip()
        columns = [col.strip() for col in row['Compare_Columns'].split(',')]
        key_column = row['Key_Column'].strip() if 'Key_Column' in row else columns[0]  # fallback

        print(f"\n Comparing: {src_schema}.{src_table} vs {tgt_schema}.{tgt_table}")

        try:
            src_query = f"SELECT {', '.join(columns)} FROM {src_schema}.{src_table}"
            tgt_query = f"SELECT {', '.join(columns)} FROM {tgt_schema}.{tgt_table}"

            src_df = pd.read_sql(src_query, conn).astype(str)
            tgt_df = pd.read_sql(tgt_query, conn).astype(str)

            src_df.set_index(key_column, inplace=True)
            tgt_df.set_index(key_column, inplace=True)

            # Rows only in source
            only_in_source = src_df[~src_df.index.isin(tgt_df.index)].head(10).reset_index()

            # Rows only in target
            only_in_target = tgt_df[~tgt_df.index.isin(src_df.index)].head(10).reset_index()

            # Matching keys with mismatched values
            common_keys = src_df.index.intersection(tgt_df.index)
            mismatches = []
            for key in common_keys:
                if not src_df.loc[key].equals(tgt_df.loc[key]):
                    mismatch_row = {"Key": key}
                    for col in columns:
                        src_val = src_df.loc[key][col] if col in src_df.columns else None
                        tgt_val = tgt_df.loc[key][col] if col in tgt_df.columns else None
                        if src_val != tgt_val:
                            mismatch_row[f"{col}_SRC"] = src_val
                            mismatch_row[f"{col}_TGT"] = tgt_val
                    mismatches.append(mismatch_row)
            mismatched_df = pd.DataFrame(mismatches).head(10)

            # Write to Excel
            output_file = os.path.join(output_dir, f"{src_table}_vs_{tgt_table}.xlsx")
            wb = Workbook()
            wb.remove(wb.active)

            write_df_to_sheet(wb, "only_in_source", only_in_source)
            write_df_to_sheet(wb, "only_in_target", only_in_target)
            write_df_to_sheet(wb, "mismatches", mismatched_df)

            wb.save(output_file)
            print(f" Comparison Excel saved: {output_file}")

        except Exception as e:
            print(f" Error comparing tables {src_table} and {tgt_table}: {e}")

    conn.close()
    print(" Snowflake connection closed.")

if __name__ == "__main__":
    run_table_comparison("compare_config.xlsx")
