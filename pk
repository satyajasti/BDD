import pandas as pd
import os
from openpyxl import Workbook, load_workbook
from openpyxl.utils.dataframe import dataframe_to_rows
from snowflake_connection import get_snowflake_connection
from pattern_validation import read_pattern_rules, run_pattern_validation

def write_df_to_sheet(wb, sheet_name, df):
    print(f" Writing to sheet: {sheet_name} (Rows: {len(df)})")
    ws = wb.create_sheet(title=sheet_name)
    for row in dataframe_to_rows(df, index=False, header=True):
        if any(row):
            ws.append(row)

def run_pattern_validations(config_path, pattern_excel_path):
    #  Set a separate output directory for pattern validation results
    output_dir = "reports/pattern_validation_outputs"
    os.makedirs(output_dir, exist_ok=True)

    # Load pattern validation rules
    pattern_rules_df = read_pattern_rules(pattern_excel_path)
    print("\n Loaded pattern rules:")
    print(pattern_rules_df)

    # Connect to Snowflake
    conn, database, _, _, _, _ = get_snowflake_connection(config_path)

    # Track status for each rule
    pattern_status = []

    try:
        # Group by table+schema for efficient processing
        grouped = pattern_rules_df.groupby(['Table', 'Schema'])

        for (table, schema), group_rules in grouped:
            table = table.strip()
            schema = schema.strip()
            print(f"\n Running pattern validations for: {database}.{schema}.{table}")

            try:
                summary_df, invalid_df = run_pattern_validation(conn, group_rules, database)

                # Define Excel file path
                output_file = os.path.join(output_dir, f"{table}.xlsx")

                # Load or create workbook
                if os.path.exists(output_file):
                    wb = load_workbook(output_file)
                    print(f" Updating existing workbook: {output_file}")
                else:
                    wb = Workbook()
                    wb.remove(wb.active)
                    print(f" Creating new workbook: {output_file}")

                # Write sheets
                write_df_to_sheet(wb, "pattern_summary", summary_df)
                if not invalid_df.empty:
                    write_df_to_sheet(wb, "invalid_data_sample", invalid_df)

                wb.save(output_file)
                print(f" Pattern results saved: {output_file}")

                pattern_status.append({
                    "Table": table,
                    "Schema": schema,
                    "Status": "Success",
                    "Error": ""
                })

            except Exception as e:
                print(f" Error for table {table}: {e}")
                pattern_status.append({
                    "Table": table,
                    "Schema": schema,
                    "Status": "Failed",
                    "Error": str(e)
                })

    finally:
        conn.close()
        print(" Snowflake connection closed.")

    # Write pattern validation status
    status_df = pd.DataFrame(pattern_status)
    status_file = os.path.join(output_dir, "pattern_validation_status_summary.xlsx")
    status_df.to_excel(status_file, index=False)
    print(f"\n Pattern validation status saved to: {status_file}")

if __name__ == "__main__":
    config_path = "config.json"
    pattern_excel_path = "pattern_rules.xlsx"  # Excel containing pattern validation rules
    run_pattern_validations(config_path, pattern_excel_path)
