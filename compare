# Recreate hybrid SQL comparison script after reset

hybrid_compare_script = """
import os
import sys
import sqlglot
import pandas as pd
from sqlglot import expressions as exp
from moz_sql_parser import parse as moz_parse
from datetime import datetime

def parse_with_sqlglot(sql_text):
    try:
        return sqlglot.parse_one(sql_text).to_dict(), "sqlglot"
    except Exception as e:
        print(f"⚠️ sqlglot failed: {e}")
        return None, None

def parse_with_moz(sql_text):
    try:
        return moz_parse(sql_text), "moz_sql_parser"
    except Exception as e:
        print(f"❌ moz_sql_parser also failed: {e}")
        return None, None

def extract_select_columns(parsed_tree, parser_type):
    if not parsed_tree:
        return []
    try:
        if parser_type == "sqlglot":
            return [col.get("name") or col.get("alias") for col in parsed_tree.get("select", []) if isinstance(col, dict)]
        elif parser_type == "moz_sql_parser":
            return list(parsed_tree.get("select", {}).keys())
    except Exception as e:
        print(f"Error extracting columns: {e}")
    return []

def extract_tables(parsed_tree, parser_type):
    if not parsed_tree:
        return []
    try:
        if parser_type == "sqlglot":
            froms = parsed_tree.get("from", [])
            return [tbl.get("this") for tbl in froms if isinstance(tbl, dict) and "this" in tbl]
        elif parser_type == "moz_sql_parser":
            frm = parsed_tree.get("from", {})
            if isinstance(frm, dict):
                return [frm.get("value")]
            elif isinstance(frm, list):
                return [item.get("value") if isinstance(item, dict) else item for item in frm]
            else:
                return [frm]
    except Exception as e:
        print(f"Error extracting tables: {e}")
    return []

def compare_lists(list1, list2):
    set1, set2 = set(list1), set(list2)
    return list(set1 - set2), list(set2 - set1)

def generate_excel_report(table_diffs, column_diffs, summary, output_path="sql_diff_report.xlsx"):
    with pd.ExcelWriter(output_path, engine="openpyxl", mode="w") as writer:
        pd.DataFrame(table_diffs, columns=["Only in Query 1", "Only in Query 2"]).to_excel(writer, index=False, sheet_name="Table_Diff")
        pd.DataFrame(column_diffs, columns=["Only in Query 1", "Only in Query 2"]).to_excel(writer, index=False, sheet_name="Column_Diff")
        pd.DataFrame([summary]).to_excel(writer, index=False, sheet_name="Summary")
    print(f"📄 Excel report saved to: {output_path}")

def compare_sql_files(file1, file2):
    with open(file1, "r") as f:
        sql1 = f.read()
    with open(file2, "r") as f:
        sql2 = f.read()

    # Try sqlglot first
    parsed1, parser1 = parse_with_sqlglot(sql1)
    parsed2, parser2 = parse_with_sqlglot(sql2)

    # Fallback to moz if sqlglot fails
    if not parsed1:
        parsed1, parser1 = parse_with_moz(sql1)
    if not parsed2:
        parsed2, parser2 = parse_with_moz(sql2)

    if not parsed1 or not parsed2:
        print("❌ Failed to parse both queries.")
        return

    print(f"✅ Parsed Query 1 using: {parser1}")
    print(f"✅ Parsed Query 2 using: {parser2}")

    cols1 = extract_select_columns(parsed1, parser1)
    cols2 = extract_select_columns(parsed2, parser2)

    tbls1 = extract_tables(parsed1, parser1)
    tbls2 = extract_tables(parsed2, parser2)

    missing_cols1, missing_cols2 = compare_lists(cols1, cols2)
    missing_tbls1, missing_tbls2 = compare_lists(tbls1, tbls2)

    # Console output
    print("\\n=== COLUMN COMPARISON ===")
    print("Only in Query 1:", missing_cols1)
    print("Only in Query 2:", missing_cols2)

    print("\\n=== TABLE COMPARISON ===")
    print("Only in Query 1:", missing_tbls1)
    print("Only in Query 2:", missing_tbls2)

    verdict = "PASS" if not (missing_cols1 or missing_cols2 or missing_tbls1 or missing_tbls2) else "REVIEW"
    summary = {
        "Query 1": os.path.basename(file1),
        "Query 2": os.path.basename(file2),
        "Verdict": verdict,
        "Generated On": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    }

    generate_excel_report(
        table_diffs=[(missing_tbls1[i] if i < len(missing_tbls1) else "", missing_tbls2[i] if i < len(missing_tbls2) else "") for i in range(max(len(missing_tbls1), len(missing_tbls2)))],
        column_diffs=[(missing_cols1[i] if i < len(missing_cols1) else "", missing_cols2[i] if i < len(missing_cols2) else "") for i in range(max(len(missing_cols1), len(missing_cols2)))],
        summary=summary
    )

if __name__ == "__main__":
    compare_sql_files("abc_query.sql", "obc_query.sql")
"""

with open("/mnt/data/sql_compare_queries.py", "w") as f:
    f.write(hybrid_compare_script.strip())

"/mnt/data/sql_compare_queries.py"
