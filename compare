import os
from sqlglot import parse_one, expressions as exp
import pandas as pd
from datetime import datetime

def extract_all(expr, clause_type):
    return [str(x).lower() for x in expr.find_all(clause_type)]

def extract_groupby(expr):
    group_expr = expr.args.get("group")
    return [str(e).lower() for e in group_expr] if group_expr else []

def extract_having(expr):
    having_expr = expr.args.get("having")
    return str(having_expr).lower() if having_expr else ""

def compare_lists(list1, list2):
    set1, set2 = set(list1), set(list2)
    return list(set1 - set2), list(set2 - set1)

def compare_queries(file1, file2):
    with open(file1, "r") as f1, open(file2, "r") as f2:
        sql1 = f1.read()
        sql2 = f2.read()

    parsed1 = parse_one(sql1, read="snowflake")
    parsed2 = parse_one(sql2, read="snowflake")

    def extract(parsed):
        return {
            "tables": extract_all(parsed, exp.Table),
            "columns": extract_all(parsed, exp.Column),
            "joins": extract_all(parsed, exp.Join),
            "where": extract_all(parsed, exp.Where),
            "groupby": extract_groupby(parsed),
            "having": extract_having(parsed)
        }

    data1 = extract(parsed1)
    data2 = extract(parsed2)

    result = {}
    for key in data1:
        if isinstance(data1[key], list):
            only1, only2 = compare_lists(data1[key], data2[key])
            result[key] = {"only_in_query_1": only1, "only_in_query_2": only2}
        else:
            result[key] = {
                "query_1": data1[key],
                "query_2": data2[key],
                "match": data1[key] == data2[key]
            }

    output = pd.ExcelWriter("sql_comparison_report.xlsx", engine='openpyxl')
    for section, values in result.items():
        if isinstance(values, dict) and "only_in_query_1" in values:
            df = pd.DataFrame({
                "Only in Query 1": values["only_in_query_1"],
                "Only in Query 2": values["only_in_query_2"]
            })
            df.to_excel(output, sheet_name=section.capitalize(), index=False)
        else:
            df = pd.DataFrame([values])
            df.to_excel(output, sheet_name=section.capitalize(), index=False)
    output.close()

    print("✅ Comparison complete. Report: sql_comparison_report.xlsx")

# Example usage
compare_queries("abc_query.sql", "obc_query.sql")
