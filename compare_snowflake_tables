import pandas as pd
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from snowflake_connectivity import get_snowflake_connection  # Assuming you have this function in the file

# Function to fetch DESCRIBE TABLE results from Snowflake
def describe_table(conn, schema_name, table_name):
    query = f"DESCRIBE TABLE {schema_name}.{table_name}"
    cur = conn.cursor()
    cur.execute(query)
    data = cur.fetchall()
    df = pd.DataFrame(data, columns=[desc[0] for desc in cur.description])
    cur.close()
    return df

# Function to compare the describe results of two tables
def compare_describe_results(df1, df2):
    mismatches = []
    
    # Compare both DataFrames
    for index, row1 in df1.iterrows():
        if not row1.equals(df2.iloc[index]):
            mismatches.append((index, row1, df2.iloc[index]))
    
    return mismatches

# Function to highlight mismatches in Excel
def highlight_mismatches(writer, sheet_name, mismatches):
    workbook = writer.book
    worksheet = writer.sheets[sheet_name]
    fill = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")
    
    for mismatch in mismatches:
        row_num = mismatch[0] + 2  # Excel row starts from 1, account for header
        worksheet[f"A{row_num}"].fill = fill
        worksheet[f"B{row_num}"].fill = fill

# Main function to run the comparison and write results to Excel and console
def main():
    # Get connection and table names from JSON config
    conn, schema_name, table_1_name, table_2_name = get_snowflake_connection('config.json')  # Updated to use existing function

    # Describe both tables
    df_table_1 = describe_table(conn, schema_name, table_1_name)
    df_table_2 = describe_table(conn, schema_name, table_2_name)

    # Compare describe results
    mismatches = compare_describe_results(df_table_1, df_table_2)

    # Output file for the results
    output_file = 'describe_table_comparison.xlsx'

    # Write the results to Excel
    with pd.ExcelWriter(output_file, engine='openpyxl') as writer:
        df_table_1.to_excel(writer, sheet_name=f'{table_1_name}_Describe', index=False)
        df_table_2.to_excel(writer, sheet_name=f'{table_2_name}_Describe', index=False)

        # Highlight mismatches in both sheets
        highlight_mismatches(writer, f'{table_1_name}_Describe', mismatches)
        highlight_mismatches(writer, f'{table_2_name}_Describe', mismatches)

    # Print mismatches in console
    if mismatches:
        print("\nMismatches found:")
        for mismatch in mismatches:
            index, row1, row2 = mismatch
            print(f"Mismatch at row {index}:")
            print(f"Table 1: {row1}")
            print(f"Table 2: {row2}")
    else:
        print("\nNo mismatches found.")

    # Close the Snowflake connection
    conn.close()

if __name__ == "__main__":
    main()
