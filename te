def find_columns_with_identical_chars(df, columns):
    """
    Identify columns where values have all identical characters,
    excluding single-character values and null/empty values.
    """
    def has_identical_chars(value):
        """
        Check if all characters in a string are the same.
        Exclude single-character values and null/empty values.
        """
        if pd.isnull(value) or str(value).strip() == "":
            return False  # Ignore null or empty values

        value = str(value).strip()
        return len(value) > 1 and len(set(value)) == 1  # Multi-character identical values only

    # Filter columns to check if any value satisfies the condition
    columns_with_identical_chars = []

    for col in columns:
        if df[col].apply(has_identical_chars).any():  # Check if any value satisfies the condition
            columns_with_identical_chars.append(col)

    # Filter rows where any column contains identical characters
    if columns_with_identical_chars:
        filtered_df = df[df[columns_with_identical_chars].apply(lambda col: col.apply(has_identical_chars)).any(axis=1)]
        return columns_with_identical_chars, filtered_df
    else:
        return [], pd.DataFrame()  # Return empty DataFrame if no columns satisfy the condition








